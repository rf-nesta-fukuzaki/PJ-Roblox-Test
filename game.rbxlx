					<string name="ScriptGuid">{e8467f98-31c9-4f42-b0ff-40577f64bbe1}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">Hello</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">06786fbfddfabcf409b8414600000399</UniqueId>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX3a41cff0f3204b15ab15054ec3253e64">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[-- ゲームバランス定数

local Config = {}

-- 初期ステータス値
Config.InitialStats = {
	DashPower   = 0,
	JumpPower   = 0,
	FlightPower = 0,
}

-- クリックあたりの成長量
Config.PowerPerClick = {
	DashPower   = 1,
	JumpPower   = 1,
	FlightPower = 1,
}

-- 進化段階の閾値（DashPower基準）
Config.EvolutionThresholds = { 100, 500, 2000, 10000, 50000 }

-- 惑星アンロックに必要な到達高度
Config.PlanetAltitude = {
	Moon   = 1000,
	Mars   = 5000,
	Saturn = 20000,
}

return Config
]]></ProtectedString>
					<string name="ScriptGuid">{6f9b8f75-fdf1-4fa8-b38d-07cdd63313f2}</string>
					<BinaryString name="AttributesSerialize"></BinaryString>
					<SecurityCapabilities name="Capabilities">0</SecurityCapabilities>
					<bool name="DefinesCapabilities">false</bool>
					<UniqueId name="HistoryId">00000000000000000000000000000000</UniqueId>
					<string name="Name">Config</string>
					<int64 name="SourceAssetId">-1</int64>
					<BinaryString name="Tags"></BinaryString>
					<UniqueId name="UniqueId">5d03be59ee8cd2dd09b935f100000907</UniqueId>
				</Properties>
			</Item>
			<Item class="ModuleScript" referent="RBX6ada0c237b094a62be2b04c56cf88c68">
				<Properties>
					<Content name="LinkedSource"><null></null></Content>
					<ProtectedString name="Source"><![CDATA[-- プレイヤーステータス管理モジュール（セッション中メモリのみ）

local Config = require(script.Parent.Config)

local PlayerData = {}

-- 内部ステータステーブル
local data = {
	DashPower     = Config.InitialStats.DashPower,
	JumpPower     = Config.InitialStats.JumpPower,
	FlightPower   = Config.InitialStats.FlightPower,
	MaxAltitude   = 0,
	Coins         = 0,
	CurrentPlanet = "Earth",
}

-- 現在のデータテーブルを返す（コピーで返すことで外部からの直接書き換えを防ぐ）
function PlayerData.getData(): { [string]: any }
	local copy = {}
	for k, v in pairs(data) do
		copy[k] = v
	end
	return copy
end

-- 指定ステータスに amount を加算する
function PlayerData.addPower(statName: string, amount: number)
	assert(data[statName] ~= nil, "PlayerData.addPower: 不明なステータス名: " .. tostring(statName))
	assert(type(amount) == "number", "PlayerData.addPower: amount は数値である必要があります")
	data[statName] = data[statName] + amount
end

-- 現在の進化段階を返す（0 = 初期、Config.EvolutionThresholds の数だけ段階が上がる）
function PlayerData.getEvolutionStage(): number
	local thresholds = Config.EvolutionThresholds
	local stage = 0
	for _, threshold in ipairs(thresholds) do
		if data.DashPower >= threshold then
			stage += 1
		else
			break
		end
	end
	return stage
end

-- 初期状態にリセット（テスト用）
function PlayerData.reset()
	data.DashPower     = Config.InitialStats.DashPower
	data.JumpPower     = Config.InitialStats.JumpPower
	data.FlightPower   = Config.InitialStats.FlightPower
	data.MaxAltitude   = 0
	data.Coins         = 0
	data.CurrentPlanet = "Earth"
end

return PlayerData
]]></ProtectedString>
