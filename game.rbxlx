        <Item class="ModuleScript" referent="15">
          <Properties>
            <string name="Name">AltitudeTracker</string>
            <string name="Source"><![CDATA[-- 高度追跡・表示モジュール

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService        = game:GetService("RunService")
local TweenService      = game:GetService("TweenService")

local PlayerData   = require(ReplicatedStorage.Shared.PlayerData)
local MiniHUD      = require(script.Parent.MiniHUD)
local Effects      = require(script.Parent.Effects)
local SoundManager = require(script.Parent.SoundManager)

local LocalPlayer = Players.LocalPlayer

local AltitudeTracker = {}

-- リーダーボード更新用RemoteEvent（非同期取得）
local updateLeaderboardRE = nil :: RemoteEvent?
task.spawn(function()
	updateLeaderboardRE = ReplicatedStorage:WaitForChild("UpdateLeaderboard") :: RemoteEvent
end)

-- ─────────────────────────────────────────
-- 高度マーカー定義
-- ─────────────────────────────────────────

local MARKERS = {
	{ altitude = 100,  icon = "☁️",  text = "100m突破！"  },
	{ altitude = 500,  icon = "✨",  text = "500m突破！"  },
	{ altitude = 1000, icon = "⭐",  text = "1000m突破！" },
	{ altitude = 2000, icon = "🌟",  text = "2000m突破！" },
	{ altitude = 5000, icon = "🚀",  text = "5000m突破！" },
}

-- ─────────────────────────────────────────
-- 内部状態
-- ─────────────────────────────────────────

local passedMarkers          = {} :: { [number]: boolean }
local recordNoticeVersion    = 0
local milestoneNoticeVersion = 0

-- 着地検出
local wasAirborne = false
local peakY       = 0

local currentAltLabel = nil :: TextLabel?
local bestAltLabel    = nil :: TextLabel?
local recordNotice    = nil :: TextLabel?
local milestoneNotice = nil :: TextLabel?

-- ─────────────────────────────────────────
-- 通知ヘルパー
-- ─────────────────────────────────────────

local function showRecordNotice(altitude: number)
	if not recordNotice then return end
	recordNoticeVersion += 1
	local v = recordNoticeVersion

	recordNotice.Text                   = "🎉 新記録！ " .. altitude .. "m！"
	recordNotice.TextTransparency       = 0
	recordNotice.BackgroundTransparency = 0.15
	recordNotice.Visible                = true

	TweenService:Create(
		recordNotice,
		TweenInfo.new(2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ TextTransparency = 1, BackgroundTransparency = 1 }
	):Play()

	task.delay(2, function()
		if recordNoticeVersion == v then
			recordNotice.Visible = false
		end
	end)
end

local function showMilestoneNotice(icon: string, text: string)
	if not milestoneNotice then return end
	milestoneNoticeVersion += 1
	local v = milestoneNoticeVersion

	milestoneNotice.Text                   = icon .. " " .. text
	milestoneNotice.TextTransparency       = 0
	milestoneNotice.BackgroundTransparency = 0.15
	milestoneNotice.Visible                = true

	TweenService:Create(
		milestoneNotice,
		TweenInfo.new(1.5, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ TextTransparency = 1, BackgroundTransparency = 1 }
	):Play()

	task.delay(1.5, function()
		if milestoneNoticeVersion == v then
			milestoneNotice.Visible = false
		end
	end)
end

-- ─────────────────────────────────────────
-- 公開API
-- ─────────────────────────────────────────

function AltitudeTracker.resetMilestones()
	passedMarkers = {}
	wasAirborne   = false
	peakY         = 0
end

function AltitudeTracker.init()
	local playerGui = LocalPlayer:WaitForChild("PlayerGui")

	-- ScreenGui ------------------------------------------------
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name         = "AltitudeHUD"
	screenGui.ResetOnSpawn = false
	screenGui.Parent       = playerGui

	-- 右側パネル -----------------------------------------------
	local panel = Instance.new("Frame")
	panel.Name                   = "AltitudePanel"
	panel.AnchorPoint            = Vector2.new(1, 0)
	panel.Size                   = UDim2.new(0, 170, 0, 64)
	panel.Position               = UDim2.new(1, -12, 0, 76)
	panel.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
	panel.BackgroundTransparency = 0.45
	panel.BorderSizePixel        = 0
	panel.Parent                 = screenGui

	local panelCorner = Instance.new("UICorner")
	panelCorner.CornerRadius = UDim.new(0, 8)
	panelCorner.Parent       = panel

	local panelPad = Instance.new("UIPadding")
	panelPad.PaddingLeft   = UDim.new(0, 10)
	panelPad.PaddingRight  = UDim.new(0, 10)
	panelPad.PaddingTop    = UDim.new(0, 8)
	panelPad.PaddingBottom = UDim.new(0, 8)
	panelPad.Parent        = panel

	local panelList = Instance.new("UIListLayout")
	panelList.FillDirection     = Enum.FillDirection.Vertical
	panelList.VerticalAlignment = Enum.VerticalAlignment.Top
	panelList.Padding           = UDim.new(0, 4)
	panelList.Parent            = panel

	currentAltLabel = Instance.new("TextLabel")
	currentAltLabel.Name                   = "CurrentAlt"
	currentAltLabel.Size                   = UDim2.new(1, 0, 0, 24)
	currentAltLabel.BackgroundTransparency = 1
	currentAltLabel.Text                   = "📍 現在高度: 0m"
	currentAltLabel.TextColor3             = Color3.fromRGB(180, 230, 255)
	currentAltLabel.Font                   = Enum.Font.GothamBold
	currentAltLabel.TextSize               = 14
	currentAltLabel.TextXAlignment         = Enum.TextXAlignment.Left
	currentAltLabel.Parent                 = panel

	bestAltLabel = Instance.new("TextLabel")
	bestAltLabel.Name                   = "BestAlt"
	bestAltLabel.Size                   = UDim2.new(1, 0, 0, 20)
	bestAltLabel.BackgroundTransparency = 1
	bestAltLabel.Text                   = "🏔️ 自己ベスト: 0m"
	bestAltLabel.TextColor3             = Color3.fromRGB(255, 220, 100)
	bestAltLabel.Font                   = Enum.Font.Gotham
	bestAltLabel.TextSize               = 14
	bestAltLabel.TextXAlignment         = Enum.TextXAlignment.Left
	bestAltLabel.Parent                 = panel

	-- 新記録通知（画面中央やや上）-------------------------------
	recordNotice = Instance.new("TextLabel")
	recordNotice.Name                   = "RecordNotice"
	recordNotice.AnchorPoint            = Vector2.new(0.5, 0.5)
	recordNotice.Size                   = UDim2.new(0, 460, 0, 72)
	recordNotice.Position               = UDim2.new(0.5, 0, 0.35, 0)
	recordNotice.BackgroundColor3       = Color3.fromRGB(20, 40, 80)
	recordNotice.BackgroundTransparency = 1
	recordNotice.Text                   = ""
	recordNotice.TextColor3             = Color3.fromRGB(100, 220, 255)
	recordNotice.Font                   = Enum.Font.GothamBold
	recordNotice.TextSize               = 30
	recordNotice.Visible                = false
	recordNotice.ZIndex                 = 10
	recordNotice.Parent                 = screenGui

	local recordCorner = Instance.new("UICorner")
	recordCorner.CornerRadius = UDim.new(0, 14)
	recordCorner.Parent       = recordNotice

	-- マイルストーン通知（画面中央）-----------------------------
	milestoneNotice = Instance.new("TextLabel")
	milestoneNotice.Name                   = "MilestoneNotice"
	milestoneNotice.AnchorPoint            = Vector2.new(0.5, 0.5)
	milestoneNotice.Size                   = UDim2.new(0, 360, 0, 60)
	milestoneNotice.Position               = UDim2.new(0.5, 0, 0.48, 0)
	milestoneNotice.BackgroundColor3       = Color3.fromRGB(20, 50, 20)
	milestoneNotice.BackgroundTransparency = 1
	milestoneNotice.Text                   = ""
	milestoneNotice.TextColor3             = Color3.fromRGB(150, 255, 150)
	milestoneNotice.Font                   = Enum.Font.GothamBold
	milestoneNotice.TextSize               = 24
	milestoneNotice.Visible                = false
	milestoneNotice.ZIndex                 = 10
	milestoneNotice.Parent                 = screenGui

	local milestoneCorner = Instance.new("UICorner")
	milestoneCorner.CornerRadius = UDim.new(0, 12)
	milestoneCorner.Parent       = milestoneNotice

	-- Heartbeatで高度を監視（0.1秒間隔）-----------------------
	local elapsed = 0
	RunService.Heartbeat:Connect(function(dt: number)
		elapsed += dt
		if elapsed < 0.1 then return end
		elapsed = 0

		local char = LocalPlayer.Character
		if not char then return end
		local root     = char:FindFirstChild("HumanoidRootPart") :: BasePart?
		local humanoid = char:FindFirstChildOfClass("Humanoid")  :: Humanoid?
		if not root or not humanoid then return end

		local rawY     = root.Position.Y
		local altitude = math.floor(math.max(0, rawY))

		-- 高度表示（高さに応じてテキストサイズ 14→22 に変化）
		currentAltLabel.TextSize = math.clamp(14 + rawY * 0.003, 14, 22)
		currentAltLabel.Text     = "📍 現在高度: " .. altitude .. "m"

		local d = PlayerData.getData()
		bestAltLabel.Text = "🏔️ 自己ベスト: " .. (d.MaxAltitude :: number) .. "m"

		-- 自己ベスト更新（地面より上のみ）
		if rawY > 0 and PlayerData.updateMaxAltitude(altitude) then
			showRecordNotice(altitude)
			Effects.newRecordFlash()
			SoundManager.playNewRecord()
			MiniHUD.update()
			-- リーダーボードに送信
			if updateLeaderboardRE then
				local d = PlayerData.getData()
				updateLeaderboardRE:FireServer(d.MaxAltitude, d.RebirthCount)
			end
		end

		-- 高度マーカー通過チェック
		for _, marker in ipairs(MARKERS) do
			if not passedMarkers[marker.altitude] and altitude >= marker.altitude then
				passedMarkers[marker.altitude] = true
				showMilestoneNotice(marker.icon, marker.text)
			end
		end

		-- 着地検出: 空中→着地、かつ落下距離 >= 50 スタッド
		local airborne = humanoid.FloorMaterial == Enum.Material.Air
		if airborne then
			peakY = math.max(peakY, rawY)
		else
			if wasAirborne then
				local fallDist = peakY - rawY
				if fallDist >= 50 then
					Effects.landingDust(root.Position)
					SoundManager.playLanding()
				end
				peakY = rawY
			end
		end
		wasAirborne = airborne
	end)
end

return AltitudeTracker
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="16">
          <Properties>
            <string name="Name">DistanceTracker</string>
            <string name="Source"><![CDATA[-- 走行距離トラッカー: 水平移動距離でSpeedとPowerGaugeを上げる

local Players           = game:GetService("Players")
local RunService        = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local PlayerData         = require(ReplicatedStorage.Shared.PlayerData)
local MiniHUD            = require(script.Parent.MiniHUD)
local MovementController = require(script.Parent.MovementController)

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

local DistanceTracker = {}

-- ─────────────────────────────────────────
-- 定数
-- ─────────────────────────────────────────
local MIN_HORIZONTAL   = 0.5   -- カウントする最小水平移動距離（スタッド）
local TELEPORT_LIMIT   = 50    -- これ以上の移動はテレポートとして無視
local UPDATE_INTERVAL  = 0.2   -- PlayerData/UI更新のスロットリング間隔（秒）

-- ─────────────────────────────────────────
-- 状態
-- ─────────────────────────────────────────
local prevPosition      = nil :: Vector3?
local accumulatedDist   = 0
local lastUpdateTime    = 0
local movingNow         = false

-- UI参照
local distanceLabel = nil :: TextLabel?
local meterScale    = nil :: UIScale?

-- ─────────────────────────────────────────
-- UI構築
-- ─────────────────────────────────────────
local function buildUI()
	local sg = Instance.new("ScreenGui")
	sg.Name         = "DistanceMeter"
	sg.ResetOnSpawn = false
	sg.Parent       = PlayerGui

	local bg = Instance.new("Frame")
	bg.Name                   = "MeterBg"
	bg.AnchorPoint            = Vector2.new(0.5, 1)
	bg.Size                   = UDim2.new(0, 390, 0, 44)
	bg.Position               = UDim2.new(0.5, 0, 1, -8)
	bg.BackgroundColor3       = Color3.fromRGB(0, 0, 0)
	bg.BackgroundTransparency = 0.45
	bg.BorderSizePixel        = 0
	bg.Parent                 = sg

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 12)
	corner.Parent       = bg

	local uiScale = Instance.new("UIScale")
	uiScale.Scale  = 1
	uiScale.Parent = bg
	meterScale = uiScale

	local lbl = Instance.new("TextLabel")
	lbl.Name                   = "MeterLabel"
	lbl.Size                   = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text                   = "🏃 走行距離: 0m | スピード: +0"
	lbl.TextColor3             = Color3.fromRGB(100, 220, 100)
	lbl.Font                   = Enum.Font.GothamBold
	lbl.TextSize               = 18
	lbl.Parent                 = bg

	distanceLabel = lbl
end

-- ─────────────────────────────────────────
-- ヘルパー
-- ─────────────────────────────────────────
local function refreshLabel()
	if not distanceLabel then return end
	local d = PlayerData.getData()
	distanceLabel.Text = "🏃 走行距離: " .. math.floor(d.TotalDistance) .. "m | スピード: +" .. math.floor(d.Speed)
end

local function setMovingAnim(moving: boolean)
	if moving == movingNow then return end
	movingNow = moving
	if not meterScale then return end
	TweenService:Create(
		meterScale,
		TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Scale = if moving then 1.08 else 1.0 }
	):Play()
end

-- ─────────────────────────────────────────
-- キャラクター監視
-- ─────────────────────────────────────────
local heartbeatConn = nil :: RBXScriptConnection?

local function setupCharacter(character: Model)
	local hrp = character:WaitForChild("HumanoidRootPart") :: BasePart
	prevPosition = hrp.Position

	if heartbeatConn then
		heartbeatConn:Disconnect()
		heartbeatConn = nil
	end

	heartbeatConn = RunService.Heartbeat:Connect(function()
		if not hrp or not hrp.Parent then return end

		local pos = hrp.Position
		if not prevPosition then
			prevPosition = pos
			return
		end

		local delta = pos - prevPosition
		prevPosition = pos

		-- テレポート判定
		if delta.Magnitude > TELEPORT_LIMIT then return end

		-- 水平移動距離のみカウント
		local horizontal = math.sqrt(delta.X * delta.X + delta.Z * delta.Z)

		if horizontal < MIN_HORIZONTAL then
			setMovingAnim(false)
			return
		end

		setMovingAnim(true)
		accumulatedDist += horizontal

		-- スロットリング
		local now = tick()
		if now - lastUpdateTime >= UPDATE_INTERVAL then
			lastUpdateTime = now
			PlayerData.addDistance(accumulatedDist)
			accumulatedDist = 0
			refreshLabel()
			MiniHUD.update()
			MovementController.update()
		end
	end)
end

-- ─────────────────────────────────────────
-- 公開API
-- ─────────────────────────────────────────
function DistanceTracker.init()
	buildUI()

	if LocalPlayer.Character then
		setupCharacter(LocalPlayer.Character)
	end

	LocalPlayer.CharacterAdded:Connect(function(character)
		prevPosition    = nil
		accumulatedDist = 0
		setupCharacter(character)
	end)
end

return DistanceTracker
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="17">
          <Properties>
            <string name="Name">Effects</string>
            <string name="Source"><![CDATA[-- ビジュアルエフェクト管理モジュール

local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local Debris       = game:GetService("Debris")

local LocalPlayer = Players.LocalPlayer

local Effects = {}

-- ─────────────────────────────────────────
-- 共有ScreenGui（遅延作成）
-- ─────────────────────────────────────────

local effectsGui = nil :: ScreenGui?
local flashFrame = nil :: Frame?

local function getEffectsGui(): ScreenGui
	if effectsGui and effectsGui.Parent then return effectsGui end

	local sg = Instance.new("ScreenGui")
	sg.Name           = "EffectsGui"
	sg.ResetOnSpawn   = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.Parent         = LocalPlayer.PlayerGui
	effectsGui = sg
	return sg
end

local function getFlashFrame(): Frame
	if flashFrame and flashFrame.Parent then return flashFrame end

	local f = Instance.new("Frame")
	f.Name                   = "FlashFrame"
	f.Size                   = UDim2.new(1, 0, 1, 0)
	f.BackgroundColor3       = Color3.fromRGB(255, 215, 0)
	f.BackgroundTransparency = 1
	f.BorderSizePixel        = 0
	f.ZIndex                 = 20
	f.Visible                = false
	f.Parent                 = getEffectsGui()
	flashFrame = f
	return f
end

-- ─────────────────────────────────────────
-- ダッシュトレイル管理
-- ─────────────────────────────────────────

type TrailData = { trail: Trail, a0: Attachment, a1: Attachment }
local trailCache = {} :: { [Model]: TrailData }

-- ─────────────────────────────────────────
-- 公開API
-- ─────────────────────────────────────────

-- (a) クリック時の光粒子バースト
function Effects.clickBurst(color: Color3)
	local char = LocalPlayer.Character
	if not char then return end
	local head = char:FindFirstChild("Head") :: BasePart?
	if not head then return end

	local part = Instance.new("Part")
	part.Size         = Vector3.new(0.1, 0.1, 0.1)
	part.Position     = head.Position + Vector3.new(0, 1.5, 0)
	part.Anchored     = true
	part.CanCollide   = false
	part.Transparency = 1
	part.CastShadow   = false
	part.Parent       = workspace

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new(color, Color3.fromRGB(255, 255, 255))
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.2),
		NumberSequenceKeypoint.new(1, 0),
	})
	emitter.Lifetime       = NumberRange.new(0.3, 0.6)
	emitter.Speed          = NumberRange.new(6, 12)
	emitter.SpreadAngle    = Vector2.new(60, 60)
	emitter.Rate           = 0
	emitter.LightEmission  = 0.8
	emitter.LightInfluence = 0.2
	emitter.Parent         = part

	emitter:Emit(10)
	Debris:AddItem(part, 1)
end

-- (b) ダッシュトレイル
function Effects.dashTrail(character: Model, enabled: boolean)
	if enabled then
		local cached = trailCache[character]
		if cached and cached.trail.Parent then return end

		local root = character:FindFirstChild("HumanoidRootPart") :: BasePart?
		if not root then return end

		local a0 = Instance.new("Attachment")
		a0.Position = Vector3.new(0,  1, 0)
		a0.Parent   = root

		local a1 = Instance.new("Attachment")
		a1.Position = Vector3.new(0, -1, 0)
		a1.Parent   = root

		local trail = Instance.new("Trail")
		trail.Attachment0   = a0
		trail.Attachment1   = a1
		trail.Lifetime      = 0.4
		trail.MinLength     = 0
		trail.FaceCamera    = true
		trail.LightEmission = 0.5
		trail.Color         = ColorSequence.new({
			ColorSequenceKeypoint.new(0, Color3.fromRGB(80, 255, 120)),
			ColorSequenceKeypoint.new(1, Color3.fromRGB(80, 255, 120)),
		})
		trail.Transparency = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.3),
			NumberSequenceKeypoint.new(1, 1.0),
		})
		trail.Parent = root

		trailCache[character] = { trail = trail, a0 = a0, a1 = a1 }
	else
		local cached = trailCache[character]
		if not cached then return end
		pcall(function() cached.trail:Destroy() end)
		pcall(function() cached.a0:Destroy()    end)
		pcall(function() cached.a1:Destroy()    end)
		trailCache[character] = nil
	end
end

-- (c) 新記録の金色フラッシュ
function Effects.newRecordFlash()
	local f = getFlashFrame()
	f.BackgroundColor3       = Color3.fromRGB(255, 215, 0)
	f.BackgroundTransparency = 0.45
	f.Visible = true

	TweenService:Create(
		f,
		TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 }
	):Play()

	task.delay(0.5, function()
		f.Visible = false
	end)
end

-- (d) 進化時の光爆発
function Effects.evolutionBurst(character: Model)
	local root = character:FindFirstChild("HumanoidRootPart") :: BasePart?
	if not root then return end

	local part = Instance.new("Part")
	part.Size         = Vector3.new(0.1, 0.1, 0.1)
	part.CFrame       = root.CFrame
	part.Anchored     = true
	part.CanCollide   = false
	part.Transparency = 1
	part.CastShadow   = false
	part.Parent       = workspace

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0,   Color3.fromRGB(255, 220,  50)),
		ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 140,   0)),
		ColorSequenceKeypoint.new(1,   Color3.fromRGB(255, 255, 255)),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0,   0.5),
		NumberSequenceKeypoint.new(0.5, 0.3),
		NumberSequenceKeypoint.new(1,   0),
	})
	emitter.Lifetime       = NumberRange.new(0.5, 1.0)
	emitter.Speed          = NumberRange.new(10, 25)
	emitter.SpreadAngle    = Vector2.new(180, 180)
	emitter.Rate           = 0
	emitter.LightEmission  = 1
	emitter.LightInfluence = 0
	emitter.Parent         = part

	emitter:Emit(40)

	local light = Instance.new("PointLight")
	light.Brightness = 5
	light.Range      = 20
	light.Color      = Color3.fromRGB(255, 220, 50)
	light.Parent     = part

	TweenService:Create(
		light,
		TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ Brightness = 0 }
	):Play()

	Debris:AddItem(part, 1.5)
end

-- (e) 高所着地の土煙
function Effects.landingDust(position: Vector3)
	local part = Instance.new("Part")
	part.Size         = Vector3.new(0.1, 0.1, 0.1)
	part.Position     = position
	part.Anchored     = true
	part.CanCollide   = false
	part.Transparency = 1
	part.CastShadow   = false
	part.Parent       = workspace

	local emitter = Instance.new("ParticleEmitter")
	emitter.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(180, 150, 100)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(200, 180, 140)),
	})
	emitter.Size = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.8),
		NumberSequenceKeypoint.new(1, 0),
	})
	emitter.Transparency = NumberSequence.new({
		NumberSequenceKeypoint.new(0, 0.3),
		NumberSequenceKeypoint.new(1, 1),
	})
	emitter.Lifetime    = NumberRange.new(0.4, 0.8)
	emitter.Speed       = NumberRange.new(3, 8)
	emitter.SpreadAngle = Vector2.new(70, 70)
	emitter.Rate        = 0
	emitter.RotSpeed    = NumberRange.new(-180, 180)
	emitter.Rotation    = NumberRange.new(0, 360)
	emitter.Parent      = part

	emitter:Emit(16)
	Debris:AddItem(part, 1)
end

-- ─────────────────────────────────────────
-- 通知UI（共通）
-- ─────────────────────────────────────────

local notifBg      = nil :: Frame?
local notifLabel   = nil :: TextLabel?
local notifVersion = 0

local function getNotifUI(): (Frame, TextLabel)
	if notifBg and notifBg.Parent then
		return notifBg, notifLabel :: TextLabel
	end

	local sg = Instance.new("ScreenGui")
	sg.Name           = "NotificationGui"
	sg.ResetOnSpawn   = false
	sg.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
	sg.Parent         = LocalPlayer.PlayerGui

	local bg = Instance.new("Frame")
	bg.AnchorPoint            = Vector2.new(0.5, 0)
	bg.Size                   = UDim2.new(0, 500, 0, 46)
	bg.Position               = UDim2.new(0.5, 0, 0, 80)
	bg.BackgroundColor3       = Color3.fromRGB(20, 20, 40)
	bg.BackgroundTransparency = 0.3
	bg.BorderSizePixel        = 0
	bg.Visible                = false
	bg.ZIndex                 = 50
	bg.Parent                 = sg
	notifBg = bg

	local bgCorner = Instance.new("UICorner")
	bgCorner.CornerRadius = UDim.new(0, 12)
	bgCorner.Parent       = bg

	local lbl = Instance.new("TextLabel")
	lbl.Size                   = UDim2.new(1, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text                   = ""
	lbl.TextColor3             = Color3.fromRGB(255, 255, 255)
	lbl.Font                   = Enum.Font.GothamBold
	lbl.TextSize               = 18
	lbl.ZIndex                 = 51
	lbl.Parent                 = bg
	notifLabel = lbl

	return bg, lbl
end

function Effects.showNotification(text: string, duration: number)
	local bg, lbl = getNotifUI()

	notifVersion += 1
	local myVersion = notifVersion

	lbl.Text                  = text
	lbl.TextTransparency      = 0
	bg.BackgroundTransparency = 0.3
	bg.Visible                = true

	task.delay(duration, function()
		if notifVersion ~= myVersion then return end
		TweenService:Create(bg,  TweenInfo.new(0.4, Enum.EasingStyle.Quad), { BackgroundTransparency = 1 }):Play()
		TweenService:Create(lbl, TweenInfo.new(0.4, Enum.EasingStyle.Quad), { TextTransparency = 1 }):Play()
		task.delay(0.4, function()
			if notifVersion ~= myVersion then return end
			bg.Visible = false
		end)
	end)
end

-- ─────────────────────────────────────────
-- (f) コンボテキスト演出
-- ─────────────────────────────────────────

function Effects.comboText(comboCount: number)
	local sg = getEffectsGui()

	local lbl = Instance.new("TextLabel")
	lbl.AnchorPoint            = Vector2.new(0.5, 0.5)
	lbl.Size                   = UDim2.new(0, 220, 0, 54)
	lbl.Position               = UDim2.new(0.5, 0, 0.3, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text                   = "🔥 COMBO x" .. comboCount .. "!"
	lbl.TextColor3             = Color3.fromRGB(255, 110, 50)
	lbl.Font                   = Enum.Font.GothamBold
	lbl.TextSize               = 30
	lbl.TextTransparency       = 0
	lbl.ZIndex                 = 30
	lbl.Parent                 = sg

	local sc = Instance.new("UIScale")
	sc.Scale  = 0.5
	sc.Parent = lbl

	TweenService:Create(sc, TweenInfo.new(0.12, Enum.EasingStyle.Back, Enum.EasingDirection.Out), { Scale = 1.15 }):Play()
	task.delay(0.12, function()
		TweenService:Create(sc, TweenInfo.new(0.08, Enum.EasingStyle.Quad), { Scale = 1.0 }):Play()
	end)

	task.delay(0.35, function()
		TweenService:Create(
			lbl,
			TweenInfo.new(0.45, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ Position = UDim2.new(0.5, 0, 0.22, 0), TextTransparency = 1 }
		):Play()
		task.delay(0.45, function() lbl:Destroy() end)
	end)
end

-- ─────────────────────────────────────────
-- (g) リバース紙吹雪
-- ─────────────────────────────────────────

function Effects.rebirthConfetti()
	local char = LocalPlayer.Character
	if not char then return end
	local root = char:FindFirstChild("HumanoidRootPart") :: BasePart?
	if not root then return end

	local COLORS = {
		Color3.fromRGB(255,  80,  80),
		Color3.fromRGB(255, 200,  50),
		Color3.fromRGB( 50, 255, 100),
		Color3.fromRGB( 80, 150, 255),
		Color3.fromRGB(200,  50, 255),
	}

	for i = 1, 3 do
		local offset = Vector3.new(math.random(-3, 3), math.random(0, 3), math.random(-3, 3))

		local part = Instance.new("Part")
		part.Size         = Vector3.new(0.1, 0.1, 0.1)
		part.CFrame       = root.CFrame + offset
		part.Anchored     = true
		part.CanCollide   = false
		part.Transparency = 1
		part.CastShadow   = false
		part.Parent       = workspace

		local emitter = Instance.new("ParticleEmitter")
		emitter.Color = ColorSequence.new({
			ColorSequenceKeypoint.new(0,    COLORS[1]),
			ColorSequenceKeypoint.new(0.25, COLORS[2]),
			ColorSequenceKeypoint.new(0.5,  COLORS[3]),
			ColorSequenceKeypoint.new(0.75, COLORS[4]),
			ColorSequenceKeypoint.new(1,    COLORS[5]),
		})
		emitter.Size = NumberSequence.new({
			NumberSequenceKeypoint.new(0, 0.35),
			NumberSequenceKeypoint.new(1, 0),
		})
		emitter.Lifetime       = NumberRange.new(0.8, 1.6)
		emitter.Speed          = NumberRange.new(8, 22)
		emitter.SpreadAngle    = Vector2.new(180, 180)
		emitter.Rate           = 0
		emitter.LightEmission  = 0.8
		emitter.Rotation       = NumberRange.new(0, 360)
		emitter.RotSpeed       = NumberRange.new(-360, 360)
		emitter.Parent         = part

		emitter:Emit(28)
		Debris:AddItem(part, 2)
	end
end

-- ─────────────────────────────────────────
-- (h) フレームシェイク
-- ─────────────────────────────────────────

function Effects.shakeFrame(frame: Frame, duration: number)
	local originalPos = frame.Position
	local endTime     = tick() + duration
	local intensity   = 5

	local function step()
		if tick() >= endTime then
			frame.Position = originalPos
			return
		end
		local ox = math.random(-intensity, intensity)
		local oy = math.random(-intensity, intensity)
		frame.Position = UDim2.new(
			originalPos.X.Scale,  originalPos.X.Offset + ox,
			originalPos.Y.Scale, originalPos.Y.Offset + oy
		)
		task.delay(0.04, step)
	end
	step()
end

-- ─────────────────────────────────────────
-- (i) 進化フラッシュ（ステージ別カラー）
-- ─────────────────────────────────────────

local STAGE_FLASH_COLORS = {
	Color3.fromRGB( 80, 150, 255),  -- Stage 1: 青
	Color3.fromRGB( 80, 220, 100),  -- Stage 2: 緑
	Color3.fromRGB(255, 220,  50),  -- Stage 3: 黄
	Color3.fromRGB(255, 140,  30),  -- Stage 4: オレンジ
	Color3.fromRGB(255,  80, 200),  -- Stage 5: ピンク
}

function Effects.evolutionFlash(stage: number)
	local f = getFlashFrame()
	f.BackgroundColor3       = STAGE_FLASH_COLORS[stage] or Color3.fromRGB(255, 220, 50)
	f.BackgroundTransparency = 0.35
	f.Visible                = true

	TweenService:Create(
		f,
		TweenInfo.new(0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 }
	):Play()

	task.delay(0.6, function()
		f.Visible = false
	end)
end

return Effects
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="18">
          <Properties>
            <string name="Name">GameFlow</string>
            <string name="Source"><![CDATA[-- ゲーム全体の初期化を集約するモジュール

local Players      = game:GetService("Players")
local TweenService = game:GetService("TweenService")

local LocalPlayer = Players.LocalPlayer

local GameFlow = {}

function GameFlow.init()
	local playerGui = LocalPlayer:WaitForChild("PlayerGui")

	-- ─────────────────────────────────────────
	-- 全モジュールの初期化（依存関係に沿った順序）
	-- ─────────────────────────────────────────
	local SoundManager       = require(script.Parent.SoundManager)
	local Effects            = require(script.Parent.Effects)
	local MiniHUD            = require(script.Parent.MiniHUD)
	local TrainingUI         = require(script.Parent.TrainingUI)
	local MovementController = require(script.Parent.MovementController)
	local DistanceTracker    = require(script.Parent.DistanceTracker)
	local RebirthUI          = require(script.Parent.RebirthUI)
	local ShopUI             = require(script.Parent.ShopUI)
	local ZoneDetector       = require(script.Parent.ZoneDetector)
	local AltitudeTracker    = require(script.Parent.AltitudeTracker)
	local KillBrickHandler   = require(script.Parent.KillBrickHandler)
	local PlatformPhaser     = require(script.Parent.PlatformPhaser)

	SoundManager.init()
	MiniHUD.init()
	TrainingUI.init()
	MovementController.init()
	DistanceTracker.init()
	RebirthUI.init()
	ShopUI.init()
	ZoneDetector.init()
	AltitudeTracker.init()
	KillBrickHandler.init()
	PlatformPhaser.init()

	SoundManager.playBGM()

	-- ─────────────────────────────────────────
	-- ウェルカムメッセージ（タイプライター演出）
	-- ─────────────────────────────────────────
	local sg = Instance.new("ScreenGui")
	sg.Name         = "WelcomeScreen"
	sg.ResetOnSpawn = false
	sg.Parent       = playerGui

	local bg = Instance.new("Frame")
	bg.Name                   = "WelcomeBg"
	bg.AnchorPoint            = Vector2.new(0.5, 0.5)
	bg.Size                   = UDim2.new(0, 580, 0, 150)
	bg.Position               = UDim2.new(0.5, 0, 0.40, 0)
	bg.BackgroundColor3       = Color3.fromRGB(10, 10, 20)
	bg.BackgroundTransparency = 0.15
	bg.BorderSizePixel        = 0
	bg.ZIndex                 = 20
	bg.Parent                 = sg

	local bgCorner = Instance.new("UICorner")
	bgCorner.CornerRadius = UDim.new(0, 20)
	bgCorner.Parent       = bg

	local bgList = Instance.new("UIListLayout")
	bgList.FillDirection       = Enum.FillDirection.Vertical
	bgList.HorizontalAlignment = Enum.HorizontalAlignment.Center
	bgList.VerticalAlignment   = Enum.VerticalAlignment.Center
	bgList.Padding             = UDim.new(0, 10)
	bgList.Parent              = bg

	local bgPad = Instance.new("UIPadding")
	bgPad.PaddingLeft   = UDim.new(0, 20)
	bgPad.PaddingRight  = UDim.new(0, 20)
	bgPad.PaddingTop    = UDim.new(0, 16)
	bgPad.PaddingBottom = UDim.new(0, 16)
	bgPad.Parent        = bg

	local titleLabel = Instance.new("TextLabel")
	titleLabel.Name                   = "Title"
	titleLabel.Size                   = UDim2.new(1, 0, 0, 50)
	titleLabel.BackgroundTransparency = 1
	titleLabel.Text                   = "🌟 Dash to the Stars 🌟"
	titleLabel.TextColor3             = Color3.fromRGB(255, 215, 0)
	titleLabel.Font                   = Enum.Font.GothamBold
	titleLabel.TextSize               = 34
	titleLabel.ZIndex                 = 21
	titleLabel.Parent                 = bg

	local subLabel = Instance.new("TextLabel")
	subLabel.Name                   = "Sub"
	subLabel.Size                   = UDim2.new(1, 0, 0, 26)
	subLabel.BackgroundTransparency = 1
	subLabel.Text                   = ""
	subLabel.TextColor3             = Color3.fromRGB(220, 220, 220)
	subLabel.Font                   = Enum.Font.Gotham
	subLabel.TextSize               = 18
	subLabel.ZIndex                 = 21
	subLabel.Parent                 = bg

	-- タイプライター演出
	local SUB_TEXT = "トレーニングで鍛えて、空高く飛び立て！"
	task.spawn(function()
		for i = 1, #SUB_TEXT do
			subLabel.Text = SUB_TEXT:sub(1, i)
			task.wait(0.05)
		end
	end)

	-- 3.5秒後にフェードアウト
	task.delay(3.5, function()
		local tweenInfo = TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
		TweenService:Create(bg,         tweenInfo, { BackgroundTransparency = 1 }):Play()
		TweenService:Create(titleLabel, tweenInfo, { TextTransparency = 1 }):Play()
		TweenService:Create(subLabel,   tweenInfo, { TextTransparency = 1 }):Play()
		task.delay(1, function()
			sg:Destroy()
		end)
	end)
end

return GameFlow
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="19">
          <Properties>
            <string name="Name">KillBrickHandler</string>
            <string name="Source"><![CDATA[-- KillBrick（Y=-50付近の安全ネット）に触れたらリスポーンさせる

local Players  = game:GetService("Players")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer

local KillBrickHandler = {}

function KillBrickHandler.init()
	local killBrick = Workspace:WaitForChild("KillBrick") :: BasePart

	killBrick.Touched:Connect(function(hit: BasePart)
		local char = LocalPlayer.Character
		if not char then return end
		-- hit がLocalPlayerのキャラクターに属するパーツかチェック
		if not char:IsAncestorOf(hit) then return end
		local humanoid = char:FindFirstChildOfClass("Humanoid") :: Humanoid?
		if humanoid then
			humanoid.Health = 0
		end
	end)
end

return KillBrickHandler
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="20">
          <Properties>
            <string name="Name">MiniHUD</string>
            <string name="Source"><![CDATA[-- ミニHUD: 画面左上に常時表示するステータス情報

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local PlayerData = require(ReplicatedStorage.Shared.PlayerData)
local Config     = require(ReplicatedStorage.Shared.Config)

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

local MiniHUD = {}

local initialized = false

local ROW_DEFS = {
	{ key = "JumpPower",    icon = "💪",   label = "ジャンプ力", suffix = ""   },
	{ key = "Speed",        icon = "🏃",   label = "スピード",   suffix = ""   },
	{ key = "PowerGauge",   icon = "⚡",   label = "パワー",     suffix = ""   },
	{ key = "Coins",        icon = "💰",   label = "コイン",     suffix = ""   },
	{ key = "RebirthCount", icon = "🔄",   label = "リバース",   suffix = "回" },
	{ key = "EquippedShoes",icon = "👟",   label = "装備",       suffix = ""   },
	{ key = "MaxAltitude",  icon = "🏔️", label = "最高高度",   suffix = "m"  },
	{ key = "Stage",        icon = "⭐",   label = "Stage",      suffix = ""   },
}

local rowLabels = {} :: { [string]: TextLabel }
local hudFrame  = nil :: Frame?

-- ─────────────────────────────────────────
-- ポップアニメーション
-- ─────────────────────────────────────────

local function popLabel(lbl: TextLabel)
	local sc = lbl:FindFirstChildOfClass("UIScale")
	if not sc then
		sc        = Instance.new("UIScale")
		sc.Scale  = 1
		sc.Parent = lbl
	end
	TweenService:Create(sc, TweenInfo.new(0.07, Enum.EasingStyle.Quad), { Scale = 1.2 }):Play()
	task.delay(0.07, function()
		TweenService:Create(sc, TweenInfo.new(0.12, Enum.EasingStyle.Quad), { Scale = 1.0 }):Play()
	end)
end

-- ─────────────────────────────────────────
-- 公開API
-- ─────────────────────────────────────────

function MiniHUD.update()
	if not initialized then return end
	local d     = PlayerData.getData()
	local stage = PlayerData.getEvolutionStage()

	for _, row in ipairs(ROW_DEFS) do
		local lbl = rowLabels[row.key]
		if not lbl then continue end

		local newText

		if row.key == "Stage" then
			newText = row.icon .. " " .. row.label .. ": " .. stage

		elseif row.key == "RebirthCount" then
			local count = d.RebirthCount :: number
			local nextN = count + 1
			local cb    = nextN * Config.Rebirth.ClickBonusPerRebirth
			newText = row.icon .. " " .. row.label .. ": " .. count .. row.suffix
				.. "  (次: +" .. cb .. ")"

		elseif row.key == "EquippedShoes" then
			local shoes = Config.Shoes[d.EquippedShoes]
			local name  = if shoes then shoes.name else "なし"
			newText = row.icon .. " " .. row.label .. ": " .. name

		else
			newText = row.icon .. " " .. row.label .. ": "
				.. math.floor(d[row.key] :: number) .. row.suffix
		end

		if newText ~= lbl.Text then
			lbl.Text = newText
			popLabel(lbl)
		end
	end
end

function MiniHUD.init()
	local screenGui = Instance.new("ScreenGui")
	screenGui.Name         = "MiniHUD"
	screenGui.ResetOnSpawn = false
	screenGui.Parent       = PlayerGui

	-- 背景フレーム（グラジエント付き）
	local frame = Instance.new("Frame")
	frame.Name                   = "HUDFrame"
	frame.Size                   = UDim2.new(0, 230, 0, 16)
	frame.Position               = UDim2.new(0, 12, 0, 76)
	frame.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
	frame.BackgroundTransparency = 0.3
	frame.BorderSizePixel        = 0
	frame.Parent                 = screenGui
	hudFrame = frame

	-- グラジエント背景
	local grad = Instance.new("UIGradient")
	grad.Color = ColorSequence.new({
		ColorSequenceKeypoint.new(0, Color3.fromRGB(8, 12, 30)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(18, 22, 50)),
	})
	grad.Rotation = 135
	grad.Parent   = frame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 8)
	corner.Parent       = frame

	local padding = Instance.new("UIPadding")
	padding.PaddingLeft   = UDim.new(0, 10)
	padding.PaddingRight  = UDim.new(0, 10)
	padding.PaddingTop    = UDim.new(0, 8)
	padding.PaddingBottom = UDim.new(0, 8)
	padding.Parent        = frame

	local listLayout = Instance.new("UIListLayout")
	listLayout.FillDirection     = Enum.FillDirection.Vertical
	listLayout.VerticalAlignment = Enum.VerticalAlignment.Top
	listLayout.Padding           = UDim.new(0, 2)
	listLayout.Parent            = frame

	listLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		frame.Size = UDim2.new(0, 230, 0, listLayout.AbsoluteContentSize.Y + 16)
	end)

	for _, row in ipairs(ROW_DEFS) do
		local lbl = Instance.new("TextLabel")
		lbl.Name                   = row.key .. "Label"
		lbl.Size                   = UDim2.new(1, 0, 0, 20)
		lbl.BackgroundTransparency = 1
		lbl.Text                   = row.icon .. " " .. row.label .. ": 0" .. row.suffix
		lbl.TextColor3             = Color3.fromRGB(230, 230, 230)
		lbl.Font                   = Enum.Font.Gotham
		lbl.TextSize               = 15
		lbl.TextXAlignment         = Enum.TextXAlignment.Left
		lbl.Parent                 = frame

		if row.key == "Coins" then
			lbl.TextColor3 = Color3.fromRGB(255, 215, 0)
			lbl.TextSize   = 17
			lbl.Font       = Enum.Font.GothamBold
		end

		if row.key == "EquippedShoes" then
			lbl.TextColor3 = Color3.fromRGB(180, 220, 255)
			lbl.TextSize   = 13
		end

		rowLabels[row.key] = lbl
	end

	-- リセットボタン（最下部）
	local resetBtn = Instance.new("TextButton")
	resetBtn.Size             = UDim2.new(1, 0, 0, 26)
	resetBtn.BackgroundColor3 = Color3.fromRGB(70, 20, 20)
	resetBtn.BorderSizePixel  = 0
	resetBtn.Text             = "🔄 リセット"
	resetBtn.TextColor3       = Color3.fromRGB(200, 140, 140)
	resetBtn.Font             = Enum.Font.Gotham
	resetBtn.TextSize         = 13
	resetBtn.AutoButtonColor  = false
	resetBtn.Parent           = frame

	local resetCorner = Instance.new("UICorner")
	resetCorner.CornerRadius = UDim.new(0, 6)
	resetCorner.Parent       = resetBtn

	resetBtn.MouseButton1Click:Connect(function()
		PlayerData.reset()
		-- 循環参照を避けるためlazy require
		local AltitudeTracker = require(script.Parent.AltitudeTracker)
		AltitudeTracker.resetMilestones()
		MiniHUD.update()
	end)

	resetBtn.MouseEnter:Connect(function()
		TweenService:Create(resetBtn, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(110, 30, 30) }):Play()
	end)
	resetBtn.MouseLeave:Connect(function()
		TweenService:Create(resetBtn, TweenInfo.new(0.1), { BackgroundColor3 = Color3.fromRGB(70, 20, 20) }):Play()
	end)

	initialized = true
	MiniHUD.update()
end

return MiniHUD
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="21">
          <Properties>
            <string name="Name">MovementController</string>
            <string name="Source"><![CDATA[-- キャラクターのWalkSpeed/JumpPowerをPlayerDataに基づいて更新する

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local PlayerData = require(ReplicatedStorage.Shared.PlayerData)
local Config     = require(ReplicatedStorage.Shared.Config)
local Effects    = require(script.Parent.Effects)

local LocalPlayer = Players.LocalPlayer

local MovementController = {}

-- 現在のキャラクター／Humanoid参照（リスポーン時に差し替え）
local character: Model?   = nil
local humanoid: Humanoid? = nil
local trailActive         = false

-- ─────────────────────────────────────────
-- 内部ヘルパー
-- ─────────────────────────────────────────

local function applyStats()
	if not humanoid or not character then return end
	local d = PlayerData.getData()

	humanoid.WalkSpeed = math.min(
		Config.Speed.Base + (d.Speed :: number) * Config.Speed.Multiplier,
		Config.Speed.Max
	)
	humanoid.JumpPower = math.min(
		Config.Jump.Base + (d.JumpPower :: number) * Config.Jump.Multiplier,
		Config.Jump.Max
	)

	-- Speed stat > 100 のときダッシュトレイルを有効化
	local shouldTrail = (d.Speed :: number) > 100
	if shouldTrail ~= trailActive then
		trailActive = shouldTrail
		Effects.dashTrail(character, shouldTrail)
	end
end

local function onCharacterAdded(newCharacter: Model)
	-- 旧キャラクターのトレイルをキャッシュから除去
	if character then
		Effects.dashTrail(character, false)
	end

	character    = newCharacter
	trailActive  = false
	humanoid     = newCharacter:WaitForChild("Humanoid") :: Humanoid
	applyStats()
end

-- ─────────────────────────────────────────
-- 公開API
-- ─────────────────────────────────────────

function MovementController.update()
	applyStats()
end

function MovementController.init()
	local char = LocalPlayer.Character
	if char then
		onCharacterAdded(char)
	end

	LocalPlayer.CharacterAdded:Connect(onCharacterAdded)
end

return MovementController
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="22">
          <Properties>
            <string name="Name">PlatformPhaser</string>
            <string name="Source"><![CDATA[-- 一方通行プラットフォーム: 下から上への通過を許可し、上から乗ると通常の床になる

local Players    = game:GetService("Players")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local PlatformPhaser = {}

local RANGE    = 100   -- 処理対象の水平距離（スタッド）
local INTERVAL = 0.1   -- チェック間隔（秒）

function PlatformPhaser.init()
	local platforms = workspace:WaitForChild("Platforms", 10) :: Folder?
	if not platforms then
		warn("[PlatformPhaser] Workspace.Platforms が見つかりません。スキップします。")
		return
	end

	local elapsed = 0

	RunService.Heartbeat:Connect(function(dt: number)
		elapsed += dt
		if elapsed < INTERVAL then return end
		elapsed = 0

		local char = LocalPlayer.Character
		if not char then return end
		local root = char:FindFirstChild("HumanoidRootPart") :: BasePart?
		if not root then return end

		local playerPos = root.Position

		for _, obj in ipairs(platforms:GetDescendants()) do
			if not obj:IsA("BasePart") then continue end

			-- 水平距離が範囲外はスキップ
			local dx = obj.Position.X - playerPos.X
			local dz = obj.Position.Z - playerPos.Z
			if (dx * dx + dz * dz) > RANGE * RANGE then continue end

			-- プレイヤーがプラットフォームの上面より上にいるなら衝突ON
			local topY = obj.Position.Y + obj.Size.Y / 2
			if playerPos.Y > topY - 1 then
				obj.CanCollide = true
			else
				obj.CanCollide = false
			end
		end
	end)
end

return PlatformPhaser
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="23">
          <Properties>
            <string name="Name">RebirthUI</string>
            <string name="Source"><![CDATA[-- リバースステーションUI

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local PlayerData         = require(ReplicatedStorage.Shared.PlayerData)
local Config             = require(ReplicatedStorage.Shared.Config)
local MiniHUD            = require(script.Parent.MiniHUD)
local SoundManager       = require(script.Parent.SoundManager)
local MovementController = require(script.Parent.MovementController)
local Effects            = require(script.Parent.Effects)

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

local RebirthUI = {}

-- リーダーボード更新用RemoteEvent（非同期取得）
local updateLeaderboardRE = nil :: RemoteEvent?
task.spawn(function()
	updateLeaderboardRE = ReplicatedStorage:WaitForChild("UpdateLeaderboard") :: RemoteEvent
end)

-- ─────────────────────────────────────────
-- 内部参照
-- ─────────────────────────────────────────
local screenGui        = nil :: ScreenGui?
local mainPanel        = nil :: Frame?
local powerLabel       = nil :: TextLabel?
local coinPreviewLabel = nil :: TextLabel?
local rebirthBtn       = nil :: TextButton?
local bonusLabel       = nil :: TextLabel?
local flashFrame       = nil :: Frame?
local resultLabel      = nil :: TextLabel?

-- ─────────────────────────────────────────
-- スライドアニメーション定数
-- ─────────────────────────────────────────
local PANEL_CENTER  = UDim2.new(0.5, 0, 0.5, 0)
local PANEL_OFFBOT  = UDim2.new(0.5, 0, 1.5, 0)

-- ─────────────────────────────────────────
-- ヘルパー
-- ─────────────────────────────────────────

local function refreshPanel()
	local d      = PlayerData.getData()
	local power  = math.floor(d.PowerGauge)
	local earned = math.floor(power * Config.Rebirth.CoinsPerPower)
	local canDo  = PlayerData.canRebirth()

	powerLabel.Text       = "⚡ パワー: " .. power
	coinPreviewLabel.Text = "→ 💰 " .. earned .. " コイン獲得！"

	local nextCount  = (d.RebirthCount :: number) + 1
	local clickBonus = nextCount * Config.Rebirth.ClickBonusPerRebirth
	local speedBonus = nextCount * Config.Rebirth.SpeedBonusPerRebirth
	bonusLabel.Text = "次のリバースで: クリック+" .. clickBonus .. ", 走行効率+" .. speedBonus

	if canDo then
		rebirthBtn.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
		rebirthBtn.Text             = "🔄 リバース！"
		rebirthBtn.Active           = true
	else
		rebirthBtn.BackgroundColor3 = Color3.fromRGB(90, 90, 90)
		rebirthBtn.Text             = "パワーが " .. Config.Rebirth.MinPowerGauge .. " 以上必要です"
		rebirthBtn.Active           = false
	end
end

local function countUpAnim(from: number, to: number, duration: number, onTick: (n: number) -> ())
	local startTime = tick()
	task.spawn(function()
		while true do
			local t = math.min((tick() - startTime) / duration, 1)
			onTick(math.floor(from + (to - from) * t))
			if t >= 1 then break end
			task.wait(0.016)
		end
	end)
end

local function playRebirthEffect(coins: number)
	-- 画面フラッシュ
	flashFrame.BackgroundTransparency = 0.3
	TweenService:Create(
		flashFrame,
		TweenInfo.new(0.8, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
		{ BackgroundTransparency = 1 }
	):Play()

	-- パネルシェイク
	Effects.shakeFrame(mainPanel, 0.5)

	-- 紙吹雪
	Effects.rebirthConfetti()

	-- 結果テキスト
	resultLabel.Text             = "🔄 リバース完了！ 0コイン獲得！"
	resultLabel.TextTransparency = 0
	resultLabel.Visible          = true

	countUpAnim(0, coins, 1.2, function(n)
		resultLabel.Text = "🔄 リバース完了！ " .. n .. "コイン獲得！"
	end)

	task.delay(1.8, function()
		TweenService:Create(
			resultLabel,
			TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
			{ TextTransparency = 1 }
		):Play()
		task.delay(0.5, function()
			resultLabel.Visible = false
		end)
	end)
end

-- ─────────────────────────────────────────
-- 公開API（スライドアニメーション付き）
-- ─────────────────────────────────────────

function RebirthUI.show()
	if not mainPanel then return end
	refreshPanel()
	mainPanel.Position = PANEL_OFFBOT
	mainPanel.Visible  = true
	TweenService:Create(
		mainPanel,
		TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{ Position = PANEL_CENTER }
	):Play()
end

function RebirthUI.hide()
	if not mainPanel then return end
	TweenService:Create(
		mainPanel,
		TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = PANEL_OFFBOT }
	):Play()
	task.delay(0.2, function()
		if mainPanel then mainPanel.Visible = false end
	end)
end

-- ─────────────────────────────────────────
-- UI構築
-- ─────────────────────────────────────────

function RebirthUI.init()
	screenGui = Instance.new("ScreenGui")
	screenGui.Name         = "RebirthUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent       = PlayerGui

	-- 全画面フラッシュ用フレーム
	local ff = Instance.new("Frame")
	ff.Name                   = "FlashFrame"
	ff.Size                   = UDim2.new(1, 0, 1, 0)
	ff.BackgroundColor3       = Color3.fromRGB(255, 255, 200)
	ff.BackgroundTransparency = 1
	ff.BorderSizePixel        = 0
	ff.ZIndex                 = 90
	ff.Parent                 = screenGui
	flashFrame = ff

	-- メインパネル（初期非表示・下外）
	local panel = Instance.new("Frame")
	panel.Name                   = "MainPanel"
	panel.AnchorPoint            = Vector2.new(0.5, 0.5)
	panel.Size                   = UDim2.new(0, 500, 0, 380)
	panel.Position               = PANEL_OFFBOT
	panel.BackgroundColor3       = Color3.fromRGB(15, 15, 30)
	panel.BackgroundTransparency = 0.12
	panel.BorderSizePixel        = 0
	panel.Visible                = false
	panel.ZIndex                 = 10
	panel.Parent                 = screenGui
	mainPanel = panel

	local panelCorner = Instance.new("UICorner")
	panelCorner.CornerRadius = UDim.new(0, 20)
	panelCorner.Parent       = panel

	local panelStroke = Instance.new("UIStroke")
	panelStroke.Color     = Color3.fromRGB(212, 175, 55)
	panelStroke.Thickness = 2
	panelStroke.Parent    = panel

	local panelPad = Instance.new("UIPadding")
	panelPad.PaddingLeft   = UDim.new(0, 24)
	panelPad.PaddingRight  = UDim.new(0, 24)
	panelPad.PaddingTop    = UDim.new(0, 20)
	panelPad.PaddingBottom = UDim.new(0, 20)
	panelPad.Parent        = panel

	local panelList = Instance.new("UIListLayout")
	panelList.FillDirection       = Enum.FillDirection.Vertical
	panelList.HorizontalAlignment = Enum.HorizontalAlignment.Center
	panelList.VerticalAlignment   = Enum.VerticalAlignment.Top
	panelList.Padding             = UDim.new(0, 14)
	panelList.Parent              = panel

	-- タイトル
	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size                   = UDim2.new(1, 0, 0, 44)
	titleLbl.BackgroundTransparency = 1
	titleLbl.Text                   = "🔄 リバースステーション"
	titleLbl.TextColor3             = Color3.fromRGB(255, 215, 0)
	titleLbl.Font                   = Enum.Font.GothamBold
	titleLbl.TextSize               = 28
	titleLbl.ZIndex                 = 11
	titleLbl.Parent                 = panel

	-- パワー表示
	local pwrLbl = Instance.new("TextLabel")
	pwrLbl.Size                   = UDim2.new(1, 0, 0, 32)
	pwrLbl.BackgroundTransparency = 1
	pwrLbl.Text                   = "⚡ パワー: 0"
	pwrLbl.TextColor3             = Color3.fromRGB(150, 220, 255)
	pwrLbl.Font                   = Enum.Font.GothamBold
	pwrLbl.TextSize               = 22
	pwrLbl.ZIndex                 = 11
	pwrLbl.Parent                 = panel
	powerLabel = pwrLbl

	-- コイン変換プレビュー
	local coinLbl = Instance.new("TextLabel")
	coinLbl.Size                   = UDim2.new(1, 0, 0, 32)
	coinLbl.BackgroundTransparency = 1
	coinLbl.Text                   = "→ 💰 0 コイン獲得！"
	coinLbl.TextColor3             = Color3.fromRGB(255, 215, 0)
	coinLbl.Font                   = Enum.Font.GothamBold
	coinLbl.TextSize               = 22
	coinLbl.ZIndex                 = 11
	coinLbl.Parent                 = panel
	coinPreviewLabel = coinLbl

	-- ボーナス説明
	local bonusLbl = Instance.new("TextLabel")
	bonusLbl.Size                   = UDim2.new(1, 0, 0, 28)
	bonusLbl.BackgroundTransparency = 1
	bonusLbl.Text                   = "次のリバースで: クリック+0.5, 走行効率+0.02"
	bonusLbl.TextColor3             = Color3.fromRGB(180, 180, 180)
	bonusLbl.Font                   = Enum.Font.Gotham
	bonusLbl.TextSize               = 15
	bonusLbl.TextWrapped            = true
	bonusLbl.ZIndex                 = 11
	bonusLbl.Parent                 = panel
	bonusLabel = bonusLbl

	-- 区切り線
	local divider = Instance.new("Frame")
	divider.Size                   = UDim2.new(1, 0, 0, 2)
	divider.BackgroundColor3       = Color3.fromRGB(80, 80, 80)
	divider.BackgroundTransparency = 0
	divider.BorderSizePixel        = 0
	divider.ZIndex                 = 11
	divider.Parent                 = panel

	-- リバースボタン
	local rBtn = Instance.new("TextButton")
	rBtn.Size             = UDim2.new(1, 0, 0, 64)
	rBtn.BackgroundColor3 = Color3.fromRGB(212, 175, 55)
	rBtn.BorderSizePixel  = 0
	rBtn.Text             = "🔄 リバース！"
	rBtn.TextColor3       = Color3.fromRGB(255, 255, 255)
	rBtn.Font             = Enum.Font.GothamBold
	rBtn.TextSize         = 26
	rBtn.AutoButtonColor  = true
	rBtn.ZIndex           = 11
	rBtn.Parent           = panel
	rebirthBtn = rBtn

	local rBtnCorner = Instance.new("UICorner")
	rBtnCorner.CornerRadius = UDim.new(0, 14)
	rBtnCorner.Parent       = rBtn

	rBtn.MouseButton1Click:Connect(function()
		if not PlayerData.canRebirth() then return end

		local result = PlayerData.doRebirth()
		SoundManager.playRebirth()
		playRebirthEffect(result.coins)
		refreshPanel()
		MiniHUD.update()
		MovementController.update()

		if updateLeaderboardRE then
			updateLeaderboardRE:FireServer(0, result.newRebirthCount)
		end
	end)

	-- リバース完了テキスト（画面中央）
	local resLbl = Instance.new("TextLabel")
	resLbl.Name                   = "ResultLabel"
	resLbl.AnchorPoint            = Vector2.new(0.5, 0.5)
	resLbl.Size                   = UDim2.new(0, 560, 0, 70)
	resLbl.Position               = UDim2.new(0.5, 0, 0.35, 0)
	resLbl.BackgroundTransparency = 1
	resLbl.Text                   = ""
	resLbl.TextColor3             = Color3.fromRGB(255, 215, 0)
	resLbl.Font                   = Enum.Font.GothamBold
	resLbl.TextSize               = 36
	resLbl.Visible                = false
	resLbl.ZIndex                 = 95
	resLbl.Parent                 = screenGui
	resultLabel = resLbl

	refreshPanel()
end

return RebirthUI
]]></string>
          </Properties>
        </Item>
        <Item class="ModuleScript" referent="24">
          <Properties>
            <string name="Name">ShopUI</string>
            <string name="Source"><![CDATA[-- ショップUI（シューズ・トレイル購入）

local Players           = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local TweenService      = game:GetService("TweenService")

local PlayerData   = require(ReplicatedStorage.Shared.PlayerData)
local Config       = require(ReplicatedStorage.Shared.Config)
local MiniHUD      = require(script.Parent.MiniHUD)
local SoundManager = require(script.Parent.SoundManager)
local Effects      = require(script.Parent.Effects)

local LocalPlayer = Players.LocalPlayer
local PlayerGui   = LocalPlayer:WaitForChild("PlayerGui")

local ShopUI = {}

-- ─────────────────────────────────────────
-- 内部参照
-- ─────────────────────────────────────────
local screenGui   = nil :: ScreenGui?
local mainPanel   = nil :: Frame?
local coinsLabel  = nil :: TextLabel?
local scrollFrame = nil :: ScrollingFrame?
local listLayout  = nil :: UIListLayout?

local currentTab = "shoes"  -- "shoes" | "trails"
local tabBtns    = {} :: { [string]: TextButton }

-- ─────────────────────────────────────────
-- カラー定数
-- ─────────────────────────────────────────
local TAB_ACTIVE   = Color3.fromRGB(52, 152, 219)
local TAB_INACTIVE = Color3.fromRGB(50, 50, 70)

local BTN_BUY      = Color3.fromRGB(39, 174,  96)  -- 購入可能（緑）
local BTN_NOFUND   = Color3.fromRGB(176,  58,  46)  -- コイン不足（赤）
local BTN_EQUIP    = Color3.fromRGB(41,  128, 185)  -- 装備可能（青）
local BTN_EQUIPPED = Color3.fromRGB(74,   35,  90)  -- 装備中（ダーク紫）

-- アイコンマッピング（idから絵文字）
local ICON_MAP: { [string]: string } = {
	starter   = "👟",
	runner    = "🏃",
	springs   = "🦘",
	rocket    = "🚀",
	legendary = "👑",
	galaxy    = "🌌",
	none      = "✖",
	fire      = "🔥",
	ice       = "❄",
	star      = "⭐",
	rainbow   = "🌈",
}

local function getItemIcon(id: string): string
	return ICON_MAP[id] or "📦"
end

-- ─────────────────────────────────────────
-- アイテム一覧の再構築
-- ─────────────────────────────────────────

local function rebuildItems()
	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("Frame") then child:Destroy() end
	end

	local d        = PlayerData.getData()
	local coins    = d.Coins :: number
	local isShoes  = currentTab == "shoes"
	local order    = if isShoes then Config.ShoesOrder else Config.TrailsOrder
	local items    = if isShoes then Config.Shoes      else Config.Trails
	local equipped = if isShoes then d.EquippedShoes   else d.EquippedTrail

	local ITEM_H = 120

	for i, id in ipairs(order) do
		local item = items[id]
		if not item then continue end

		local owned   = if isShoes then PlayerData.hasShoes(id) else PlayerData.hasTrail(id)
		local isEquip = (equipped == id)
		local canBuy  = not owned and coins >= item.cost

		-- アイテムフレーム
		local frame = Instance.new("Frame")
		frame.Name                   = "Item_" .. id
		frame.Size                   = UDim2.new(1, -12, 0, ITEM_H)
		frame.BackgroundColor3       = Color3.fromRGB(25, 25, 45)
		frame.BackgroundTransparency = 0.2
		frame.BorderSizePixel        = 0
		frame.LayoutOrder            = i
		frame.Parent                 = scrollFrame

		local fCorner = Instance.new("UICorner")
		fCorner.CornerRadius = UDim.new(0, 10)
		fCorner.Parent       = frame

		-- アイコンフレーム（60×60、左端中央）
		local iconFrame = Instance.new("Frame")
		iconFrame.Name                   = "IconFrame"
		iconFrame.Size                   = UDim2.new(0, 56, 0, 56)
		iconFrame.Position               = UDim2.new(0, 10, 0.5, -28)
		iconFrame.BackgroundColor3       = Color3.fromRGB(40, 40, 70)
		iconFrame.BackgroundTransparency = 0
		iconFrame.BorderSizePixel        = 0
		iconFrame.Parent                 = frame

		local iconCorner = Instance.new("UICorner")
		iconCorner.CornerRadius = UDim.new(0, 12)
		iconCorner.Parent       = iconFrame

		local iconLbl = Instance.new("TextLabel")
		iconLbl.Size                   = UDim2.new(1, 0, 1, 0)
		iconLbl.BackgroundTransparency = 1
		iconLbl.Text                   = getItemIcon(id)
		iconLbl.TextSize               = 28
		iconLbl.Font                   = Enum.Font.GothamBold
		iconLbl.Parent                 = iconFrame

		-- アイテム名（アイコン右）
		local nameLbl = Instance.new("TextLabel")
		nameLbl.Size                   = UDim2.new(1, -200, 0, 26)
		nameLbl.Position               = UDim2.new(0, 76, 0, 10)
		nameLbl.BackgroundTransparency = 1
		nameLbl.Text                   = item.name
		nameLbl.TextColor3             = Color3.fromRGB(255, 255, 255)
		nameLbl.Font                   = Enum.Font.GothamBold
		nameLbl.TextSize               = 17
		nameLbl.TextXAlignment         = Enum.TextXAlignment.Left
		nameLbl.Parent                 = frame

		-- 価格（右上）
		local priceLbl = Instance.new("TextLabel")
		priceLbl.Size                   = UDim2.new(0, 100, 0, 26)
		priceLbl.Position               = UDim2.new(1, -112, 0, 10)
		priceLbl.BackgroundTransparency = 1
		priceLbl.Text                   = if item.cost == 0 then "無料" else "💰 " .. item.cost
		priceLbl.TextColor3             = Color3.fromRGB(255, 215, 0)
		priceLbl.Font                   = Enum.Font.GothamBold
		priceLbl.TextSize               = 15
		priceLbl.TextXAlignment         = Enum.TextXAlignment.Right
		priceLbl.Parent                 = frame

		-- 説明（アイコン右、2行目）
		local descLbl = Instance.new("TextLabel")
		descLbl.Size                   = UDim2.new(1, -80, 0, 20)
		descLbl.Position               = UDim2.new(0, 76, 0, 38)
		descLbl.BackgroundTransparency = 1
		descLbl.Text                   = item.description
		descLbl.TextColor3             = Color3.fromRGB(180, 180, 180)
		descLbl.Font                   = Enum.Font.Gotham
		descLbl.TextSize               = 13
		descLbl.TextXAlignment         = Enum.TextXAlignment.Left
		descLbl.Parent                 = frame

		-- ボーナス表示（シューズのみ）
		if isShoes and item.clickBonus then
			local parts = {}
			if item.clickBonus > 0 then
				table.insert(parts, "クリック +" .. item.clickBonus)
			end
			if item.runBonus and item.runBonus > 0 then
				table.insert(parts, "走行 +" .. item.runBonus)
			end
			if #parts > 0 then
				local bonusLbl = Instance.new("TextLabel")
				bonusLbl.Size                   = UDim2.new(1, -80, 0, 18)
				bonusLbl.Position               = UDim2.new(0, 76, 0, 60)
				bonusLbl.BackgroundTransparency = 1
				bonusLbl.Text                   = "✦ " .. table.concat(parts, "  /  ")
				bonusLbl.TextColor3             = Color3.fromRGB(100, 220, 150)
				bonusLbl.Font                   = Enum.Font.Gotham
				bonusLbl.TextSize               = 12
				bonusLbl.TextXAlignment         = Enum.TextXAlignment.Left
				bonusLbl.Parent                 = frame
			end
		end

		-- ボタン（右下）
		local btn = Instance.new("TextButton")
		btn.Size            = UDim2.new(0, 110, 0, 34)
		btn.Position        = UDim2.new(1, -122, 1, -44)
		btn.BorderSizePixel = 0
		btn.Font            = Enum.Font.GothamBold
		btn.TextSize        = 15
		btn.TextColor3      = Color3.fromRGB(255, 255, 255)
		btn.Parent          = frame

		local btnCorner = Instance.new("UICorner")
		btnCorner.CornerRadius = UDim.new(0, 8)
		btnCorner.Parent       = btn

		if isEquip then
			btn.Text             = "装備中 ✓"
			btn.BackgroundColor3 = BTN_EQUIPPED
			btn.Active           = false
		elseif owned then
			btn.Text             = "装備する"
			btn.BackgroundColor3 = BTN_EQUIP
			btn.Active           = true
		elseif canBuy then
			btn.Text             = "購入"
			btn.BackgroundColor3 = BTN_BUY
			btn.Active           = true
		else
			btn.Text             = "💰不足"
			btn.BackgroundColor3 = BTN_NOFUND
			btn.Active           = true  -- シェイクのためクリック可能にする
		end

		local capturedId = id
		btn.MouseButton1Click:Connect(function()
			if not btn.Active then return end

			-- コイン不足の場合はシェイクして終了
			local d2 = PlayerData.getData()
			if not owned and not isEquip and d2.Coins < item.cost then
				Effects.shakeFrame(mainPanel, 0.3)
				return
			end

			local success = false
			if isShoes then
				if owned then
					success = PlayerData.equipShoes(capturedId)
				else
					success = PlayerData.buyShoes(capturedId)
					if success then PlayerData.equipShoes(capturedId) end
				end
			else
				if owned then
					success = PlayerData.equipTrail(capturedId)
				else
					success = PlayerData.buyTrail(capturedId)
					if success then PlayerData.equipTrail(capturedId) end
				end
			end

			if success then
				SoundManager.playPurchase()
				coinsLabel.Text = "💰 " .. math.floor(PlayerData.getData().Coins)
				rebuildItems()
				MiniHUD.update()
			end
		end)
	end

	-- CanvasSizeを自動更新
	task.defer(function()
		if listLayout then
			scrollFrame.CanvasSize = UDim2.new(0, 0, 0, listLayout.AbsoluteContentSize.Y + 8)
		end
	end)
end

-- ─────────────────────────────────────────
-- タブ切り替え
-- ─────────────────────────────────────────

local function switchTab(tab: string)
	currentTab = tab
	for id, tbtn in pairs(tabBtns) do
		tbtn.BackgroundColor3 = if id == tab then TAB_ACTIVE else TAB_INACTIVE
	end
	rebuildItems()
end

-- ─────────────────────────────────────────
-- 公開API（スライドアニメーション付き）
-- ─────────────────────────────────────────

local PANEL_CENTER  = UDim2.new(0.5, 0, 0.5, 0)
local PANEL_OFFSIDE = UDim2.new(1.5, 0, 0.5, 0)

function ShopUI.show()
	if not mainPanel then return end
	coinsLabel.Text    = "💰 " .. math.floor(PlayerData.getData().Coins)
	switchTab(currentTab)
	mainPanel.Position = PANEL_OFFSIDE
	mainPanel.Visible  = true
	TweenService:Create(
		mainPanel,
		TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out),
		{ Position = PANEL_CENTER }
	):Play()
end

function ShopUI.hide()
	if not mainPanel then return end
	TweenService:Create(
		mainPanel,
		TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In),
		{ Position = PANEL_OFFSIDE }
	):Play()
	task.delay(0.2, function()
		if mainPanel then mainPanel.Visible = false end
	end)
end

-- ─────────────────────────────────────────
-- UI構築
-- ─────────────────────────────────────────

function ShopUI.init()
	screenGui = Instance.new("ScreenGui")
	screenGui.Name         = "ShopUI"
	screenGui.ResetOnSpawn = false
	screenGui.Parent       = PlayerGui

	-- メインパネル（初期非表示・右外）
	local panel = Instance.new("Frame")
	panel.Name                   = "MainPanel"
	panel.AnchorPoint            = Vector2.new(0.5, 0.5)
	panel.Size                   = UDim2.new(0, 600, 0, 500)
	panel.Position               = PANEL_OFFSIDE
	panel.BackgroundColor3       = Color3.fromRGB(15, 15, 30)
	panel.BackgroundTransparency = 0.12
	panel.BorderSizePixel        = 0
	panel.Visible                = false
	panel.ZIndex                 = 10
	panel.Parent                 = screenGui
	mainPanel = panel

	local pCorner = Instance.new("UICorner")
	pCorner.CornerRadius = UDim.new(0, 20)
	pCorner.Parent       = panel

	local pStroke = Instance.new("UIStroke")
	pStroke.Color     = Color3.fromRGB(80, 130, 200)
	pStroke.Thickness = 2
	pStroke.Parent    = panel

	-- タイトル
	local titleLbl = Instance.new("TextLabel")
	titleLbl.Size                   = UDim2.new(1, -40, 0, 50)
	titleLbl.Position               = UDim2.new(0, 20, 0, 12)
	titleLbl.BackgroundTransparency = 1
	titleLbl.Text                   = "🛒 ショップ"
	titleLbl.TextColor3             = Color3.fromRGB(255, 255, 255)
	titleLbl.Font                   = Enum.Font.GothamBold
	titleLbl.TextSize               = 28
	titleLbl.TextXAlignment         = Enum.TextXAlignment.Left
	titleLbl.ZIndex                 = 11
	titleLbl.Parent                 = panel

	-- コイン表示
	local coinsLbl = Instance.new("TextLabel")
	coinsLbl.Size                   = UDim2.new(0, 140, 0, 34)
	coinsLbl.Position               = UDim2.new(1, -160, 0, 20)
	coinsLbl.BackgroundTransparency = 1
	coinsLbl.Text                   = "💰 0"
	coinsLbl.TextColor3             = Color3.fromRGB(255, 215, 0)
	coinsLbl.Font                   = Enum.Font.GothamBold
	coinsLbl.TextSize               = 22
	coinsLbl.TextXAlignment         = Enum.TextXAlignment.Right
	coinsLbl.ZIndex                 = 11
	coinsLbl.Parent                 = panel
	coinsLabel = coinsLbl

	-- タブフレーム
	local tabFrame = Instance.new("Frame")
	tabFrame.Size                   = UDim2.new(1, -40, 0, 44)
	tabFrame.Position               = UDim2.new(0, 20, 0, 66)
	tabFrame.BackgroundTransparency = 1
	tabFrame.ZIndex                 = 11
	tabFrame.Parent                 = panel

	local tabList = Instance.new("UIListLayout")
	tabList.FillDirection       = Enum.FillDirection.Horizontal
	tabList.HorizontalAlignment = Enum.HorizontalAlignment.Left
	tabList.VerticalAlignment   = Enum.VerticalAlignment.Center
	tabList.Padding             = UDim.new(0, 10)
	tabList.Parent              = tabFrame

	local TAB_DEFS = {
		{ id = "shoes",  label = "👟 シューズ" },
		{ id = "trails", label = "✨ トレイル" },
	}

	for _, td in ipairs(TAB_DEFS) do
		local tbtn = Instance.new("TextButton")
		tbtn.Size             = UDim2.new(0, 130, 0, 40)
		tbtn.BackgroundColor3 = if td.id == "shoes" then TAB_ACTIVE else TAB_INACTIVE
		tbtn.BorderSizePixel  = 0
		tbtn.Text             = td.label
		tbtn.TextColor3       = Color3.fromRGB(255, 255, 255)
		tbtn.Font             = Enum.Font.GothamBold
		tbtn.TextSize         = 16
		tbtn.ZIndex           = 12
		tbtn.Parent           = tabFrame

		local tbtnCorner = Instance.new("UICorner")
		tbtnCorner.CornerRadius = UDim.new(0, 10)
		tbtnCorner.Parent       = tbtn

		local capturedId = td.id
		tbtn.MouseButton1Click:Connect(function()
			switchTab(capturedId)
		end)

		tabBtns[td.id] = tbtn
	end

	-- ScrollingFrame（アイテム一覧）
	local sf = Instance.new("ScrollingFrame")
	sf.Name                   = "ItemList"
	sf.Size                   = UDim2.new(1, -40, 1, -130)
	sf.Position               = UDim2.new(0, 20, 0, 118)
	sf.BackgroundTransparency = 1
	sf.BorderSizePixel        = 0
	sf.ScrollBarThickness     = 6
	sf.ScrollBarImageColor3   = Color3.fromRGB(100, 100, 120)
	sf.CanvasSize             = UDim2.new(0, 0, 0, 0)
	sf.ZIndex                 = 11
	sf.Parent                 = panel
	scrollFrame = sf

	local ll = Instance.new("UIListLayout")
	ll.FillDirection     = Enum.FillDirection.Vertical
	ll.VerticalAlignment = Enum.VerticalAlignment.Top
	ll.Padding           = UDim.new(0, 8)
	ll.SortOrder         = Enum.SortOrder.LayoutOrder
	ll.Parent            = sf
	listLayout = ll

	local sfPad = Instance.new("UIPadding")
	sfPad.PaddingTop    = UDim.new(0, 4)
	sfPad.PaddingBottom = UDim.new(0, 4)
	sfPad.PaddingLeft   = UDim.new(0, 4)
	sfPad.Parent        = sf

	ll:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		sf.CanvasSize = UDim2.new(0, 0, 0, ll.AbsoluteContentSize.Y + 8)
	end)
end

return ShopUI
]]></string>
          </Properties>
